# ============================================================
# Bouguedima Studio — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit a real .env file to the repository.

# ---------- Security ----------
# Secret key for JWT token signing. Generate a strong random string:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-strong-random-key
STUDIO_SECRET_KEY=replace-me-with-a-strong-random-key

# Admin credentials (bcrypt hash). Generate with:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=replace-me-with-bcrypt-hash
STUDIO_ADMIN_USER=admin

# ---------- CORS ----------
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ---------- Database ----------
# PostgreSQL Connection URL
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/studio

# PostgreSQL environment variables for the database container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=studio
POSTGRES_PORT=5432

# ---------- Logging ----------
# INFO, WARNING, ERROR, DEBUG
LOG_LEVEL=INFO
# json or plain
LOG_FORMAT=json
LOG_DIR=logs
LOG_FILE=server.log
