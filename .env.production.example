# ============================================================
# Production environment — Oracle Cloud VM
# ============================================================
# Copy to .env on the server:  cp .env.production.example .env
# NEVER commit a real .env file.

# ---------- Database ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=studio
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/studio

# ---------- Security ----------
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me
STUDIO_SECRET_KEY=replace-me

# python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('your-password'))"
ADMIN_PASSWORD_HASH=replace-me
STUDIO_ADMIN_USER=admin

# ---------- CORS (Vercel frontend + custom domain) ----------
ALLOWED_ORIGINS=https://your-app.vercel.app,https://elwarsha.tn,https://www.elwarsha.tn

# ---------- Optional ----------
BACKEND_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
