# ============================================================
# Bouguedima Studio — Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit a real .env file to the repository.

# Local Dev Server Port (optional, defaults to 5173)
# PORT=5173

# API base URL
#
# Local dev (Vite proxy): leave empty or use /api
# Production on Vercel: full API origin without trailing slash
#   VITE_API_URL=https://api.elwarsha.tn
VITE_API_URL=
