# ==========================================
# Bouguedima Studio — Global Git Ignore File
# ==========================================

# Virtual Environments
venv/
.venv/
env/
ENV/
pyvenv.cfg

# Python cache & compiler output
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
.hypothesis/
htmlcov/
*.egg-info/
.eggs/
build/
dist/

# JavaScript Dependencies & Builds
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
.eslintcache
.oxlintrc.json

# Environment Secrets
.env
.env.*
!.env.example
!.env.production.example
frontend/.env
frontend/.env.*
!frontend/.env.example
backend/.env
backend/.env.*
!backend/.env.example

# Databases & Backups
*.db
*.db-journal
*.sqlite3
postgres-data/

# OS Specific Files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
backend/logs/
backend/server.log
npm-debug.log*
yarn-debug.log*

# IDE Configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
